{
  "bsonType": "object",
  "required": ["_id", "userId", "gateway", "amount", "status", "createdAt"],
  "properties": {
    "_id": {
      "bsonType": "string",
      "description": "UUID v4"
    },
    "userId": {
      "bsonType": "string",
      "description": "User UUID"
    },
    "gateway": {
      "enum": ["simulated", "mercado_pago"]
    },
    "externalId": {
      "bsonType": ["string", "null"],
      "description": "Gateway reference/idempotency key"
    },
    "amount": {
      "bsonType": ["double", "int", "long", "decimal"],
      "minimum": 0.01
    },
    "status": {
      "enum": ["pending", "confirmed", "failed"]
    },
    "pixCpf": {
      "bsonType": "string",
      "description": "CPF usado no pagamento Pix"
    },
    "createdAt": {
      "bsonType": "date",
      "description": "ISO date"
    }
  }
}
